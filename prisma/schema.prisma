generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
}

enum TaskStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  emailVerified DateTime?
  image         String?
  projects      Project[]
  quotas        UserQuota[]
  tasks         GenerateTask[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SubscriptionPlan {
  id            String      @id @default(cuid())
  planCode      String      @unique
  name          String
  monthlyQuota  Int
  monthlyPrice  Decimal     @db.Decimal(10, 2)
  description   String?
  userQuotas    UserQuota[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model UserQuota {
  id          String           @id @default(cuid())
  userId      String
  planId      String
  totalQuota  Int
  usedQuota   Int              @default(0)
  startDate   DateTime
  endDate     DateTime
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId, startDate])
}

model Template {
  id          String         @id @default(cuid())
  name        String
  category    String
  description String?
  coverUrl    String?
  contentJson Json?
  projects    Project[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Project {
  id              String         @id @default(cuid())
  userId          String
  templateId      String?
  sourceTaskId    String?
  name            String
  status          ProjectStatus  @default(DRAFT)
  sceneType       String
  selectedImageUrl String?
  contentJson     Json?
  tasks           GenerateTask[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
}

model GenerateTask {
  id           String      @id @default(cuid())
  userId       String
  projectId    String?
  sceneType    String
  providerKey  String
  prompt       String
  inputJson    Json
  resultJson   Json?
  outputCount  Int         @default(1)
  status       TaskStatus  @default(PENDING)
  errorMessage String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, updatedAt])
}
